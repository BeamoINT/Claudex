# Never commit a real token. The installer normally discovers the API key from
# the local CLIProxyAPI config or prompts securely when one is not available.
CLAUDEX_PROXY_TOKEN=replace-with-your-local-cliproxyapi-key

# Optional overrides:
# CLAUDEX_PROXY_URL=http://127.0.0.1:8317
# CLAUDEX_PERMISSION_MODE=auto
# CLAUDEX_AUTO_MODE_MODEL=gpt-5.6-luna
# CLAUDEX_BACKGROUND_MODEL=gpt-5.6-luna
# CLAUDEX_SUBAGENT_MODEL=gpt-5.6-terra
# CLAUDEX_MAX_TOOL_USE_CONCURRENCY=3
# CLAUDEX_MAX_AGENT_CONCURRENCY=3
# CLAUDEX_MAX_RETRIES=2
# CLAUDEX_CONTEXT_WINDOW=400000
# CLAUDEX_AUTO_COMPACT_WINDOW=280000
# CLAUDEX_MOUSE_POINTER_SHAPE=pointer
