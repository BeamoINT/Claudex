#!/usr/bin/env bash
set -euo pipefail

readonly config_dir="${CLAUDEX_CONFIG_DIR:-$HOME/.config/claudex}"
readonly cache_dir="$config_dir/usage-cache"
readonly cache_file="$cache_dir/limits.json"
readonly summary_file="$cache_dir/summary"
readonly last_attempt_file="$cache_dir/last-attempt"
readonly last_success_file="$cache_dir/last-success"
readonly refresh_lock="$cache_dir/refresh.lock"
readonly refresh_owner_file="$refresh_lock/owner-pid"
readonly account_selection_file="$config_dir/codex-usage-account"
readonly usage_generation_file="$config_dir/usage-generation"
readonly curl_bin="${CLAUDEX_CURL_BIN:-curl}"
readonly usage_url="${CLAUDEX_USAGE_URL:-https://chatgpt.com/backend-api/wham/usage}"
readonly refresh_seconds="${CLAUDEX_USAGE_REFRESH_SECONDS:-300}"
readonly timeout_seconds="${CLAUDEX_USAGE_TIMEOUT_SECONDS:-8}"
readonly max_stale_seconds="${CLAUDEX_USAGE_MAX_STALE_SECONDS:-86400}"
readonly usage_source="${CLAUDEX_USAGE_SOURCE:-auto}"
readonly alert_percent="${CLAUDEX_USAGE_ALERT_PERCENT:-20}"

mode=detail
refresh=1
lock_held=0
lock_token=""
account_action=""
account_selector=""
temporary_curl_config=""
temporary_limits_file=""
temporary_appserver_dir=""
appserver_pid=""
appserver_process_group=""
appserver_stdout_drain_pid=""
appserver_stderr_drain_pid=""
appserver_timeout_pid=""
appserver_input_open=0

fail() {
  printf 'usage-limit: %s\n' "$*" >&2
  return 1
}

invalidate_usage_cache() {
  rm -f "$cache_file" "$summary_file" "$last_attempt_file" "$last_success_file"
  mkdir -p "$config_dir"
  local temporary_generation
  temporary_generation=$(mktemp "$config_dir/.usage-generation.tmp.XXXXXX") || return 1
  (umask 077; printf '%s-%s-%s\n' "$(date +%s)" "$$" "${RANDOM:-0}" > "$temporary_generation")
  chmod 600 "$temporary_generation" 2>/dev/null || true
  mv -f "$temporary_generation" "$usage_generation_file"
}

read_usage_generation() {
  local generation="missing"
  if [[ -r "$usage_generation_file" ]]; then
    IFS= read -r generation < "$usage_generation_file" || generation=missing
  fi
  printf '%s\n' "$generation"
}

new_lock_token() {
  printf '%s-%s-%s\n' "$(date +%s)" "$$" "${RANDOM:-0}"
}

read_refresh_owner() {
  local owner_dir="${1:-$refresh_lock}" owner_record="" owner_file
  owner_file="$owner_dir/owner-pid"
  if [[ -r "$owner_file" ]]; then
    IFS= read -r owner_record < "$owner_file" || owner_record=""
  fi
  printf '%s\n' "$owner_record"
}

quarantine_refresh_lock() {
  local expected_record="$1" quarantine moved_record
  quarantine="$cache_dir/.refresh.lock.quarantine.$$.$RANDOM"
  mv "$refresh_lock" "$quarantine" 2>/dev/null || return 1
  moved_record=$(read_refresh_owner "$quarantine")
  if [[ "$moved_record" == "$expected_record" ]]; then
    rm -f "$quarantine/owner-pid"
    rmdir "$quarantine" 2>/dev/null || true
    return 0
  fi
  # We moved a newer generation. Restore it if the canonical path is still
  # free; otherwise preserve the quarantined directory for recovery rather
  # than deleting a lock we do not own.
  if [[ ! -e "$refresh_lock" ]]; then
    mv "$quarantine" "$refresh_lock" 2>/dev/null || true
  fi
  return 1
}

release_refresh_lock() {
  local current_record=""
  (( lock_held )) && [[ -n "$lock_token" ]] || return 0
  current_record=$(read_refresh_owner)
  [[ "${current_record#* }" == "$lock_token" ]] || return 0
  quarantine_refresh_lock "$current_record" || return 0
  lock_held=0
}

acquire_refresh_lock() {
  local refresh_owner="" refresh_pid="" observed_record=""
  (( lock_held == 0 )) || return 0
  mkdir -p "$cache_dir"
  chmod 700 "$cache_dir" 2>/dev/null || true
  if ! mkdir "$refresh_lock" 2>/dev/null; then
    observed_record=$(read_refresh_owner)
    refresh_pid="${observed_record%% *}"
    refresh_owner="${observed_record#* }"
    if [[ "$refresh_pid" =~ ^[0-9]+$ && -n "$refresh_owner" ]] && ! kill -0 "$refresh_pid" 2>/dev/null; then
      # Recheck the generation before reclaiming so a stale observer cannot
      # remove a lock whose ownership record changed while it was inspecting.
      if [[ "$(read_refresh_owner)" == "$observed_record" ]]; then
        quarantine_refresh_lock "$observed_record" || true
      fi
      mkdir "$refresh_lock" 2>/dev/null || {
        fail 'another usage refresh is already in progress.'
        return 1
      }
    else
      fail 'another usage refresh is already in progress.'
      return 1
    fi
  fi
  lock_token=$(new_lock_token)
  lock_held=1
  (umask 077; printf '%s %s\n' "$$" "$lock_token" > "$refresh_owner_file")
}

usage() {
  printf '%s\n' 'Usage: claudex --usage-limit [--cached|--json|--refresh|--accounts|--account SELECTOR]'
}

while (( $# > 0 )); do
  case "$1" in
    --cached) refresh=0 ;;
    --refresh) refresh=1 ;;
    --json) mode=json ;;
    --statusline) mode=statusline; refresh=0 ;;
    --refresh-cache) mode=refresh-cache; refresh=1 ;;
    --lock-held) lock_held=1 ;;
    --lock-token)
      shift
      (( $# > 0 )) || { fail '--lock-token requires a generation token.'; exit 2; }
      lock_token="$1"
      ;;
    --accounts) account_action=list; refresh=0 ;;
    --account)
      shift
      (( $# > 0 )) || { fail '--account requires a number, email, filename, or auto.'; exit 2; }
      account_action=select
      account_selector="$1"
      refresh=0
      ;;
    --no-color) ;;
    --help|-h) usage; exit 0 ;;
    *) fail "unknown argument: $1"; usage >&2; exit 2 ;;
  esac
  shift
done

if (( lock_held )) && [[ ! "$lock_token" =~ ^[A-Za-z0-9._-]{8,128}$ ]]; then
  fail '--lock-held requires a valid --lock-token generation.'
  exit 2
fi

if [[ ! "$refresh_seconds" =~ ^[0-9]+$ ]] || (( refresh_seconds < 60 || refresh_seconds > 3600 )); then
  fail 'CLAUDEX_USAGE_REFRESH_SECONDS must be an integer from 60 to 3600.'
  exit 2
fi
if [[ ! "$timeout_seconds" =~ ^[0-9]+$ ]] || (( timeout_seconds < 1 || timeout_seconds > 30 )); then
  fail 'CLAUDEX_USAGE_TIMEOUT_SECONDS must be an integer from 1 to 30.'
  exit 2
fi
if [[ ! "$max_stale_seconds" =~ ^[0-9]+$ ]] || (( max_stale_seconds < refresh_seconds || max_stale_seconds > 604800 )); then
  fail 'CLAUDEX_USAGE_MAX_STALE_SECONDS must be between the refresh interval and 604800.'
  exit 2
fi
case "$usage_source" in auto|web|app-server) ;;
  *) fail 'CLAUDEX_USAGE_SOURCE must be auto, web, or app-server.'; exit 2 ;;
esac
if [[ ! "$alert_percent" =~ ^[0-9]+$ ]] || (( alert_percent < 0 || alert_percent > 100 )); then
  fail 'CLAUDEX_USAGE_ALERT_PERCENT must be an integer from 0 to 100.'
  exit 2
fi

process_children() {
  ps -axo pid=,ppid= 2>/dev/null | awk -v parent="$1" '$2 == parent { print $1 }'
}

signal_process_tree() {
  local root_pid="$1" signal_name="$2" child_pid
  while IFS= read -r child_pid; do
    [[ "$child_pid" =~ ^[0-9]+$ ]] || continue
    signal_process_tree "$child_pid" "$signal_name"
  done < <(process_children "$root_pid")
  kill "-$signal_name" "$root_pid" 2>/dev/null || true
}

drain_capped_stream() {
  local source_fifo="$1" destination_file="$2" byte_limit="$3"
  local line="" line_bytes remaining written=0
  # The app-server protocol is JSONL. A shell-builtin writer keeps each
  # complete response visible to the polling loop immediately, while the
  # reader continues draining after the persisted diagnostic cap is reached.
  # This avoids stdio buffering in `head`, which can otherwise hide a small
  # response until EOF and make a healthy app-server look timed out.
  LC_ALL=C
  while IFS= read -r line || [[ -n "$line" ]]; do
    line_bytes=${#line}
    if (( written < byte_limit )); then
      remaining=$(( byte_limit - written ))
      if (( line_bytes + 1 <= remaining )); then
        printf '%s\n' "$line" >> "$destination_file"
        written=$(( written + line_bytes + 1 ))
      else
        printf '%s' "${line:0:remaining}" >> "$destination_file"
        written=$byte_limit
      fi
    fi
  done < "$source_fifo"
}

terminate_appserver() {
  local attempt
  [[ "$appserver_input_open" == 0 ]] || { exec 9>&- 2>/dev/null || true; appserver_input_open=0; }
  if [[ -n "$appserver_timeout_pid" ]]; then
    kill -TERM "$appserver_timeout_pid" 2>/dev/null || true
    wait "$appserver_timeout_pid" 2>/dev/null || true
    appserver_timeout_pid=""
  fi
  if [[ -n "$appserver_pid" ]]; then
    if [[ -n "$appserver_process_group" ]]; then
      kill -TERM -- "-$appserver_process_group" 2>/dev/null || true
      kill -TERM "$appserver_pid" 2>/dev/null || true
    else
      signal_process_tree "$appserver_pid" TERM
    fi
    for attempt in {1..10}; do
      kill -0 "$appserver_pid" 2>/dev/null || break
      sleep 0.05
    done
    if [[ -n "$appserver_process_group" ]]; then
      # KILL the group even if its leader exited after TERM; a descendant may
      # still be holding a redirected pipe open or deliberately ignoring TERM.
      kill -KILL -- "-$appserver_process_group" 2>/dev/null || true
      kill -KILL "$appserver_pid" 2>/dev/null || true
    elif kill -0 "$appserver_pid" 2>/dev/null; then
        signal_process_tree "$appserver_pid" KILL
    fi
    wait "$appserver_pid" 2>/dev/null || true
    appserver_pid=""
    appserver_process_group=""
  fi
  for attempt in "$appserver_stdout_drain_pid" "$appserver_stderr_drain_pid"; do
    [[ -n "$attempt" ]] || continue
    for _ in {1..10}; do
      kill -0 "$attempt" 2>/dev/null || break
      sleep 0.05
    done
    kill -TERM "$attempt" 2>/dev/null || true
    wait "$attempt" 2>/dev/null || true
  done
  appserver_stdout_drain_pid=""
  appserver_stderr_drain_pid=""
}

finish_appserver() {
  terminate_appserver
  [[ -z "$temporary_appserver_dir" ]] || rm -rf "$temporary_appserver_dir"
  temporary_appserver_dir=""
}

cleanup() {
  [[ -z "$temporary_curl_config" ]] || rm -f "$temporary_curl_config"
  [[ -z "$temporary_limits_file" ]] || rm -f "$temporary_limits_file"
  terminate_appserver
  [[ -z "$temporary_appserver_dir" ]] || rm -rf "$temporary_appserver_dir"
  release_refresh_lock
}
trap cleanup EXIT

file_mtime() {
  if stat -f '%m' "$1" >/dev/null 2>&1; then
    stat -f '%m' "$1"
  else
    stat -c '%Y' "$1"
  fi
}

proxy_auth_dir() {
  local proxy_config="${CLAUDEX_PROXY_CONFIG:-$config_dir/cliproxyapi.yaml}"
  local configured=""
  if [[ -r "$proxy_config" ]]; then
    configured=$(awk '
      /^[[:space:]]*auth-dir:[[:space:]]*/ {
        sub(/^[[:space:]]*auth-dir:[[:space:]]*/, "")
        gsub(/^"|"$/, "")
        gsub(/^'\''|'\''$/, "")
        print
        exit
      }
    ' "$proxy_config")
  fi
  configured="${CLAUDEX_CODEX_AUTH_DIR:-${configured:-$HOME/.cli-proxy-api}}"
  case "$configured" in
    '~') configured="$HOME" ;;
    '~/'*) configured="$HOME/${configured#\~/}" ;;
  esac
  printf '%s\n' "$configured"
}

find_auth_file() {
  local candidate newest="" newest_mtime=-1 candidate_mtime
  if [[ -n "${CLAUDEX_CODEX_AUTH_FILE:-}" ]]; then
    [[ -r "$CLAUDEX_CODEX_AUTH_FILE" ]] || return 1
    jq -e '.type == "codex"
      and (.access_token | type == "string" and length > 0)
      and ((.disabled // false) != true)
      and ((.expired // false) != true)' \
      "$CLAUDEX_CODEX_AUTH_FILE" >/dev/null 2>&1 || return 1
    printf '%s\n' "$CLAUDEX_CODEX_AUTH_FILE"
    return 0
  fi

  local auth_dir
  auth_dir=$(proxy_auth_dir)
  [[ -d "$auth_dir" ]] || return 1
  if [[ -r "$account_selection_file" ]]; then
    local selected_name
    IFS= read -r selected_name < "$account_selection_file" || selected_name=""
    case "$selected_name" in ''|*/*|*\\*) return 1 ;; esac
    candidate="$auth_dir/$selected_name"
    if [[ -r "$candidate" ]] && jq -e '.type == "codex"
      and (.access_token | type == "string" and length > 0)
      and ((.disabled // false) != true)
      and ((.expired // false) != true)' \
      "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
    return 1
  fi
  while IFS= read -r -d '' candidate; do
    jq -e '.type == "codex"
      and (.access_token | type == "string" and length > 0)
      and ((.disabled // false) != true)
      and ((.expired // false) != true)' \
      "$candidate" >/dev/null 2>&1 || continue
    candidate_mtime=$(file_mtime "$candidate" 2>/dev/null || printf 0)
    if (( candidate_mtime > newest_mtime )); then
      newest="$candidate"
      newest_mtime=$candidate_mtime
    fi
  done < <(find "$auth_dir" -maxdepth 1 -type f -name 'codex*.json' -print0 2>/dev/null)
  [[ -n "$newest" ]] || return 1
  printf '%s\n' "$newest"
}

usage_auth_binding() {
  local auth_file digest
  auth_file=$(find_auth_file) || return 1
  if command -v shasum >/dev/null 2>&1; then
    digest=$(shasum -a 256 "$auth_file" | awk '{print $1}')
  elif command -v sha256sum >/dev/null 2>&1; then
    digest=$(sha256sum "$auth_file" | awk '{print $1}')
  else
    digest=$(cksum "$auth_file" | awk '{print $1 ":" $2}')
  fi
  printf '%s\t%s\n' "$auth_file" "$digest"
}

list_accounts() {
  local auth_dir active candidate index=0 email disabled expired marker suffix
  auth_dir=$(proxy_auth_dir)
  [[ -d "$auth_dir" ]] || { fail 'CLIProxyAPI Codex OAuth directory was not found.'; return 1; }
  active=$(find_auth_file 2>/dev/null || true)
  printf '%s\n' 'Codex usage accounts:'
  while IFS= read -r -d '' candidate; do
    jq -e '.type == "codex" and (.access_token | type == "string" and length > 0)' "$candidate" >/dev/null 2>&1 || continue
    index=$(( index + 1 ))
    email=$(jq -r '.email // "unknown account"' "$candidate")
    disabled=$(jq -r '.disabled // false' "$candidate")
    expired=$(jq -r '.expired // false' "$candidate")
    [[ "$candidate" == "$active" ]] && marker='*' || marker=' '
    suffix=""
    [[ "$disabled" != true ]] || suffix=" (disabled)"
    [[ "$expired" != true ]] || suffix=" (expired)"
    printf '[%s] %d. %s%s\n' "$marker" "$index" "$email" "$suffix"
  done < <(find "$auth_dir" -maxdepth 1 -type f -name 'codex*.json' -print0 2>/dev/null)
  (( index > 0 )) || { fail 'no CLIProxyAPI Codex OAuth credentials were found.'; return 1; }
  printf '%s\n' 'Select one with: claudex --account <number|email|filename>; use auto to follow the newest credential.'
}

select_account() {
  local selector="$1" auth_dir candidate index=0 email selected=""
  if [[ "$selector" == auto ]]; then
    rm -f "$account_selection_file"
    invalidate_usage_cache
    printf '%s\n' 'Codex usage account selection: automatic (newest refreshed credential).'
    return 0
  fi
  auth_dir=$(proxy_auth_dir)
  [[ -d "$auth_dir" ]] || { fail 'CLIProxyAPI Codex OAuth directory was not found.'; return 1; }
  while IFS= read -r -d '' candidate; do
    jq -e '.type == "codex" and (.access_token | type == "string" and length > 0)' "$candidate" >/dev/null 2>&1 || continue
    index=$(( index + 1 ))
    email=$(jq -r '.email // empty' "$candidate")
    if [[ "$selector" == "$index" || "$selector" == "$email" || "$selector" == "$(basename "$candidate")" ]]; then
      jq -e '((.disabled // false) != true) and ((.expired // false) != true)' "$candidate" >/dev/null 2>&1 || {
        fail "Codex account '$selector' is disabled or expired."
        return 1
      }
      selected="$candidate"
      break
    fi
  done < <(find "$auth_dir" -maxdepth 1 -type f -name 'codex*.json' -print0 2>/dev/null)
  [[ -n "$selected" ]] || { fail "no Codex account matched '$selector'. Run: claudex --accounts"; return 1; }
  umask 077
  printf '%s\n' "$(basename "$selected")" > "$account_selection_file"
  chmod 600 "$account_selection_file" 2>/dev/null || true
  invalidate_usage_cache
  printf 'Selected Codex usage account: %s\n' "$(jq -r '.email // "unknown account"' "$selected")"
}

case "$account_action" in
  list) list_accounts; exit ;;
  select) select_account "$account_selector"; exit ;;
esac

fetch_web_usage() {
  local auth_file token account raw
  auth_file=$(find_auth_file) || {
    fail 'no CLIProxyAPI Codex OAuth credential was found; run the installer with --login.'
    return 1
  }
  token=$(jq -er '.access_token' "$auth_file") || return 1
  account=$(jq -er '.account_id // empty' "$auth_file") || account=""
  case "$token$account" in
    *$'\n'*|*$'\r'*|*'"'*) fail 'the Codex credential contains unsupported characters.'; return 1 ;;
  esac

  umask 077
  temporary_curl_config=$(mktemp "$cache_dir/.curl.tmp.XXXXXX") || return 1
  {
    printf 'header = "Authorization: Bearer %s"\n' "$token"
    [[ -z "$account" ]] || printf 'header = "ChatGPT-Account-Id: %s"\n' "$account"
    printf '%s\n' 'header = "Accept: application/json"'
  } > "$temporary_curl_config" || return 1
  raw=$("$curl_bin" --silent --show-error --fail --connect-timeout 3 \
    --max-time "$timeout_seconds" --config "$temporary_curl_config" "$usage_url") || {
      rm -f "$temporary_curl_config"
      temporary_curl_config=""
      fail 'OpenAI usage refresh failed.'
      return 1
    }
  rm -f "$temporary_curl_config"
  temporary_curl_config=""
  printf '%s' "$raw"
}

valid_raw_usage_response() {
  jq -e '
    def valid_window:
      type == "object"
      and ((.used_percent // .usedPercent) | type) == "number"
      and ((.used_percent // .usedPercent) >= 0)
      and ((.used_percent // .usedPercent) <= 100)
      and ((.limit_window_seconds // ((.windowDurationMins // 0) * 60)) | type) == "number"
      and ((.limit_window_seconds // ((.windowDurationMins // 0) * 60)) > 0);
    ((.rate_limit.primary_window // .rate_limit.secondary_window) | valid_window)
  ' >/dev/null 2>&1
}

fetch_appserver_usage() {
  command -v codex >/dev/null 2>&1 || { fail 'Codex CLI is unavailable for the app-server fallback.'; return 1; }
  if [[ -n "${CLAUDEX_CODEX_AUTH_FILE:-}" || -r "$account_selection_file" ]]; then
    fail 'app-server fallback is disabled while an explicit usage account is selected.'
    return 1
  fi

  local input_fifo output_fifo error_fifo output_file error_file attempts response="" initialized=0
  temporary_appserver_dir=$(mktemp -d "${TMPDIR:-/tmp}/claudex-appserver.XXXXXX") || return 1
  input_fifo="$temporary_appserver_dir/input"
  output_fifo="$temporary_appserver_dir/stdout"
  error_fifo="$temporary_appserver_dir/stderr"
  output_file="$temporary_appserver_dir/output"
  error_file="$temporary_appserver_dir/error"
  if ! mkfifo "$input_fifo" "$output_fifo" "$error_fifo"; then
    rm -rf "$temporary_appserver_dir"
    temporary_appserver_dir=""
    return 1
  fi
  : > "$output_file"
  : > "$error_file"
  # Continuously drain both streams so the app-server can never deadlock on a
  # full pipe. Persist at most 1 MiB of stdout and 64 KiB of stderr; excess is
  # discarded while the process remains alive.
  drain_capped_stream "$output_fifo" "$output_file" 1048576 &
  appserver_stdout_drain_pid=$!
  drain_capped_stream "$error_fifo" "$error_file" 65536 &
  appserver_stderr_drain_pid=$!
  if ! exec 9<>"$input_fifo"; then
    finish_appserver
    return 1
  fi
  appserver_input_open=1
  if command -v setsid >/dev/null 2>&1; then
    setsid codex app-server <"$input_fifo" >"$output_fifo" 2>"$error_fifo" 9>&- &
    appserver_process_group=$!
  elif command -v perl >/dev/null 2>&1; then
    perl -MPOSIX -e 'POSIX::setsid() >= 0 or die "setsid failed: $!"; exec @ARGV' \
      codex app-server <"$input_fifo" >"$output_fifo" 2>"$error_fifo" 9>&- &
    appserver_process_group=$!
  else
    codex app-server <"$input_fifo" >"$output_fifo" 2>"$error_fifo" 9>&- &
  fi
  appserver_pid=$!
  # Enforce the timeout with one wall-clock watchdog. Poll-count budgets can
  # drift across platforms when shell scheduling or fractional sleeps differ,
  # accidentally giving initialization and retrieval separate effective
  # windows. The watchdog covers the complete protocol exchange.
  (
    sleep "$timeout_seconds"
    kill -TERM "$appserver_pid" 2>/dev/null || true
  ) &
  appserver_timeout_pid=$!
  if ! printf '%s\n' '{"id":1,"method":"initialize","params":{"clientInfo":{"name":"Claudex","title":"Claudex usage fallback","version":"1.0.0"}}}' >&9; then
    finish_appserver
    fail 'Codex app-server closed during initialization.'
    return 1
  fi
  # One shared budget covers initialization and rate-limit retrieval. This is
  # deliberately not reset after initialize succeeds.
  attempts=$(( timeout_seconds * 20 ))
  while (( attempts > 0 )); do
    if jq -e 'select(.id == 1 and .result)' "$output_file" >/dev/null 2>&1; then
      initialized=1
      break
    fi
    kill -0 "$appserver_pid" 2>/dev/null || break
    attempts=$(( attempts - 1 ))
    sleep 0.05
  done
  if (( ! initialized )); then
    finish_appserver
    fail 'Codex app-server initialization timed out.'
    return 1
  fi

  if ! printf '%s\n' '{"method":"initialized"}' '{"id":2,"method":"account/rateLimits/read","params":null}' >&9; then
    finish_appserver
    fail 'Codex app-server closed before the rate-limit request.'
    return 1
  fi
  while (( attempts > 0 )); do
    response=$(jq -c 'select(.id == 2 and .result) | .result' "$output_file" 2>/dev/null | tail -1)
    [[ -z "$response" ]] || break
    kill -0 "$appserver_pid" 2>/dev/null || break
    attempts=$(( attempts - 1 ))
    sleep 0.05
  done
  finish_appserver
  [[ -n "$response" ]] || { fail 'Codex app-server returned no rate-limit snapshot.'; return 1; }

  printf '%s' "$response" | jq '
    def window:
      if type == "object"
          and (.usedPercent | type) == "number"
          and (.usedPercent >= 0 and .usedPercent <= 100)
          and (.windowDurationMins | type) == "number"
          and (.windowDurationMins > 0) then {
        used_percent: (.usedPercent // 0),
        limit_window_seconds: ((.windowDurationMins // 0) * 60),
        reset_after_seconds: 0,
        reset_at: (.resetsAt // 0)
      } else null end;
    def limit:
      if type == "object" then {
        allowed: (.rateLimitReachedType == null),
        limit_reached: (.rateLimitReachedType != null),
        primary_window: (.primary | window),
        secondary_window: (.secondary | window)
      } else null end;
    . as $root
    | {
        plan_type: (.rateLimits.planType // null),
        rate_limit: (.rateLimits | limit),
        code_review_rate_limit: null,
        additional_rate_limits: [
          (.rateLimitsByLimitId // {} | to_entries[]) as $entry
          | select($entry.value.limitId != $root.rateLimits.limitId)
          | {
              limit_name: ($entry.value.limitName // $entry.key),
              metered_feature: $entry.value.limitId,
              rate_limit: ($entry.value | limit)
            }
        ],
        credits: (if (.rateLimits.credits | type) == "object" then {
          has_credits: (.rateLimits.credits.hasCredits // false),
          unlimited: (.rateLimits.credits.unlimited // false),
          overage_limit_reached: false,
          balance: (.rateLimits.credits.balance // null)
        } else null end),
        spend_control: {reached: false},
        rate_limit_reached_type: (.rateLimits.rateLimitReachedType // null),
        rate_limit_reset_credits: {available_count: (.rateLimitResetCredits.availableCount // 0)}
      }
  '
}

window_label_short() {
  local seconds="$1"
  if (( seconds > 0 && seconds % 604800 == 0 )); then
    printf '%sd' "$(( seconds / 86400 ))"
  elif (( seconds > 0 && seconds % 86400 == 0 )); then
    printf '%sd' "$(( seconds / 86400 ))"
  elif (( seconds > 0 && seconds % 3600 == 0 )); then
    printf '%sh' "$(( seconds / 3600 ))"
  elif (( seconds > 0 && seconds % 60 == 0 )); then
    printf '%sm' "$(( seconds / 60 ))"
  else
    printf '%ss' "$seconds"
  fi
}

window_label_long() {
  local seconds="$1" amount
  if (( seconds > 0 && seconds % 86400 == 0 )); then
    amount=$(( seconds / 86400 )); printf '%s-day' "$amount"
  elif (( seconds > 0 && seconds % 3600 == 0 )); then
    amount=$(( seconds / 3600 )); printf '%s-hour' "$amount"
  elif (( seconds > 0 && seconds % 60 == 0 )); then
    amount=$(( seconds / 60 )); printf '%s-minute' "$amount"
  else
    printf '%s-second' "$seconds"
  fi
}

format_epoch() {
  local epoch="$1"
  if date -r "$epoch" '+%b %-d, %-I:%M %p' >/dev/null 2>&1; then
    date -r "$epoch" '+%b %-d, %-I:%M %p'
  else
    date -d "@$epoch" '+%b %-d, %-I:%M %p'
  fi
}

compact_summary() {
  local name seconds remaining reached label part output="" separator="" any_alert=0
  while IFS=$'\t' read -r name seconds remaining reached; do
    [[ "$seconds" =~ ^[0-9]+$ && "$remaining" =~ ^[0-9]+$ ]] || continue
    label=$(window_label_short "$seconds")
    if [[ "$name" == Codex ]]; then part="${label} ${remaining}% left"
    else part="${name} ${label} ${remaining}% left"
    fi
    output+="${separator}${part}"
    separator=' · '
    if [[ "$reached" == true ]] || (( alert_percent > 0 && remaining <= alert_percent )); then any_alert=1; fi
  done < <(jq -r '
    def remaining: (100 - ((.used_percent // 0) | floor)) | if . < 0 then 0 elif . > 100 then 100 else . end;
    def rows($name; $limit; $always; $alert):
      [$limit.primary_window, $limit.secondary_window][]?
      | select(type == "object")
      | [remaining, ($limit.limit_reached == true)] as $state
      | select($always or $state[1] or ($alert > 0 and $state[0] <= $alert))
      | [$name, (.limit_window_seconds // 0), $state[0], $state[1]] | @tsv;
    rows("Codex"; .rate_limit; true; $alert),
    rows("Review"; .code_review_rate_limit; false; $alert),
    (.additional_rate_limits[]? | rows((.limit_name // "Additional"); .rate_limit; false; $alert))
  ' --argjson alert "$alert_percent" "$cache_file" 2>/dev/null)

  if [[ -n "$output" ]]; then
    if (( any_alert )); then
      printf '⚠ Codex %s\n' "$output"
    else
      printf 'Codex %s\n' "$output"
    fi
  elif jq -e '
      .rate_limit.limit_reached == true
      or .code_review_rate_limit.limit_reached == true
      or any(.additional_rate_limits[]?; .rate_limit.limit_reached == true)
      or .rate_limit_reached_type != null
    ' \
    "$cache_file" >/dev/null 2>&1; then
    printf '%s\n' 'Codex limit reached'
  fi
}

write_summary() {
  local temporary summary
  summary=$(compact_summary) || {
    fail 'could not render the usage summary.'
    return 1
  }
  temporary=$(mktemp "$cache_dir/.summary.tmp.XXXXXX") || {
    fail 'could not create a temporary usage summary.'
    return 1
  }
  printf '%s\n' "$summary" > "$temporary" || {
    rm -f "$temporary"
    fail 'could not write the usage summary.'
    return 1
  }
  chmod 600 "$temporary" 2>/dev/null || true
  mv -f "$temporary" "$summary_file" || {
    rm -f "$temporary"
    fail 'could not publish the usage summary.'
    return 1
  }
}

refresh_cache() {
  local raw now refresh_source="" generation_at_start auth_binding_at_start=""
  mkdir -p "$cache_dir" 2>/dev/null || {
    fail "cannot create the private cache directory: $cache_dir"
    return 1
  }
  chmod 700 "$cache_dir" 2>/dev/null || true
  generation_at_start=$(read_usage_generation)
  auth_binding_at_start=$(usage_auth_binding 2>/dev/null || true)
  now=$(date +%s)
  printf '%s\n' "$now" > "$last_attempt_file" || {
    fail 'cannot record the usage refresh attempt.'
    return 1
  }
  chmod 600 "$last_attempt_file" 2>/dev/null || true

  umask 077
  temporary_limits_file=$(mktemp "$cache_dir/.limits.tmp.XXXXXX") || {
    fail 'could not create a temporary usage snapshot.'
    return 1
  }

  if [[ "$usage_source" != app-server ]]; then
    if [[ "$usage_source" == auto ]]; then
      if raw=$(fetch_web_usage 2>/dev/null) && printf '%s' "$raw" | valid_raw_usage_response; then
        refresh_source=web
      fi
    elif raw=$(fetch_web_usage); then
      if printf '%s' "$raw" | valid_raw_usage_response; then
        refresh_source=web
      else
        fail 'OpenAI returned no Codex rate-limit window.'
        return 1
      fi
    fi
    if [[ -z "$refresh_source" && "$usage_source" == web ]]; then
      return 1
    fi
  fi
  if [[ -z "$refresh_source" ]]; then
    raw=$(fetch_appserver_usage) || return 1
    refresh_source=app-server
  fi

  printf '%s' "$raw" | jq --argjson fetched_at "$now" --arg source "$refresh_source" '
    def window:
      if type == "object" then {
        used_percent: ((.used_percent // .usedPercent // 0) | tonumber),
        limit_window_seconds: ((.limit_window_seconds // ((.windowDurationMins // 0) * 60)) | tonumber),
        reset_after_seconds: ((.reset_after_seconds // 0) | tonumber),
        reset_at: ((.reset_at // .resetsAt // 0) | tonumber)
      } else null end;
    def limit:
      if type == "object" then {
        allowed: (.allowed // true),
        limit_reached: (.limit_reached // false),
        primary_window: ((.primary_window // .primary) | window),
        secondary_window: ((.secondary_window // .secondary) | window)
      } else null end;
    {
      version: 1,
      fetched_at: $fetched_at,
      source: $source,
      plan_type: (.plan_type // null),
      rate_limit: (.rate_limit | limit),
      code_review_rate_limit: (.code_review_rate_limit | limit),
      additional_rate_limits: [(.additional_rate_limits // [])[] | {
        limit_name: (.limit_name // "Additional limit"),
        metered_feature: (.metered_feature // null),
        rate_limit: (.rate_limit | limit)
      }],
      credits: (if (.credits | type) == "object" then {
        has_credits: (.credits.has_credits // false),
        unlimited: (.credits.unlimited // false),
        overage_limit_reached: (.credits.overage_limit_reached // false),
        balance: (.credits.balance // null)
      } else null end),
      spend_control_reached: (.spend_control.reached // false),
      rate_limit_reached_type: (.rate_limit_reached_type // null),
      reset_credits_available: (.rate_limit_reset_credits.available_count // 0)
    }
  ' > "$temporary_limits_file" || {
    rm -f "$temporary_limits_file"
    temporary_limits_file=""
    fail 'OpenAI returned an unrecognized usage response.'
    return 1
  }
  jq -e '
    def valid_window:
      type == "object"
      and (.used_percent | type) == "number"
      and (.used_percent >= 0 and .used_percent <= 100)
      and (.limit_window_seconds | type) == "number"
      and (.limit_window_seconds > 0);
    .fetched_at > 0
    and ((.rate_limit.primary_window // .rate_limit.secondary_window) | valid_window)
    and ([.code_review_rate_limit.primary_window?, .code_review_rate_limit.secondary_window?,
          .additional_rate_limits[]?.rate_limit.primary_window?,
          .additional_rate_limits[]?.rate_limit.secondary_window?]
         | all(. == null or valid_window))
  ' \
    "$temporary_limits_file" >/dev/null || {
      rm -f "$temporary_limits_file"
      temporary_limits_file=""
      fail 'OpenAI returned no Codex rate-limit window.'
      return 1
    }

  if [[ "$(read_usage_generation)" != "$generation_at_start" ]]; then
    rm -f "$temporary_limits_file"
    temporary_limits_file=""
    fail 'the selected Codex usage account changed during refresh; discarded the obsolete snapshot.'
    return 1
  fi
  if [[ "$refresh_source" == web && "$(usage_auth_binding 2>/dev/null || true)" != "$auth_binding_at_start" ]]; then
    rm -f "$temporary_limits_file"
    temporary_limits_file=""
    fail 'the selected Codex usage credential changed during refresh; discarded the obsolete snapshot.'
    return 1
  fi

  chmod 600 "$temporary_limits_file" 2>/dev/null || true
  mv -f "$temporary_limits_file" "$cache_file" || {
    fail 'could not publish the usage snapshot.'
    return 1
  }
  temporary_limits_file=""
  write_summary || return 1
  if [[ "$(read_usage_generation)" != "$generation_at_start" ]]; then
    rm -f "$cache_file" "$summary_file"
    fail 'the selected Codex usage account changed during refresh; discarded the obsolete snapshot.'
    return 1
  fi
  if [[ "$refresh_source" == web && "$(usage_auth_binding 2>/dev/null || true)" != "$auth_binding_at_start" ]]; then
    rm -f "$cache_file" "$summary_file"
    fail 'the selected Codex usage credential changed during refresh; discarded the obsolete snapshot.'
    return 1
  fi
  printf '%s\n' "$now" > "$last_success_file" || {
    fail 'cannot record the successful usage refresh.'
    return 1
  }
  chmod 600 "$last_success_file" 2>/dev/null || true
}

render_detail() {
  local plan fetched name seconds used reset remaining label reset_text
  plan=$(jq -r '.plan_type // "unknown"' "$cache_file")
  plan=$(printf '%s' "$plan" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')
  fetched=$(jq -r '.fetched_at // 0' "$cache_file")
  printf 'Codex usage limits (%s plan)\n' "$plan"
  while IFS=$'\t' read -r name seconds used reset; do
    [[ "$seconds" =~ ^[0-9]+$ ]] || continue
    remaining=$(( 100 - ${used%.*} ))
    (( remaining < 0 )) && remaining=0
    (( remaining > 100 )) && remaining=100
    label=$(window_label_long "$seconds")
    if [[ "$reset" =~ ^[0-9]+$ ]] && (( reset > 0 )); then
      reset_text=" · resets $(format_epoch "$reset")"
    else
      reset_text=""
    fi
    printf '%s %s: %s%% remaining (%s%% used)%s\n' \
      "$name" "$label" "$remaining" "${used%.*}" "$reset_text"
  done < <(jq -r '
    def rows($name; $limit):
      [$limit.primary_window, $limit.secondary_window][]?
      | select(type == "object")
      | [$name, (.limit_window_seconds // 0), (.used_percent // 0), (.reset_at // 0)] | @tsv;
    rows("Codex"; .rate_limit),
    rows("Code review"; .code_review_rate_limit),
    (.additional_rate_limits[]? | rows(.limit_name; .rate_limit))
  ' "$cache_file")

  local lowest_remaining source
  lowest_remaining=$(jq -r '
    [[.rate_limit.primary_window, .rate_limit.secondary_window,
      .code_review_rate_limit.primary_window, .code_review_rate_limit.secondary_window,
      .additional_rate_limits[]?.rate_limit.primary_window,
      .additional_rate_limits[]?.rate_limit.secondary_window][]?
      | select(type == "object")
      | (100 - ((.used_percent // 0) | floor))
      | if . < 0 then 0 elif . > 100 then 100 else . end] | min // 101
  ' "$cache_file")
  if (( alert_percent > 0 )) && [[ "$lowest_remaining" =~ ^[0-9]+$ ]] && (( lowest_remaining <= alert_percent )); then
    printf 'Warning: Codex capacity is at or below the configured %s%% alert threshold.\n' "$alert_percent"
  fi

  local reset_credits
  reset_credits=$(jq -r '.reset_credits_available // 0' "$cache_file")
  if [[ "$reset_credits" =~ ^[0-9]+$ ]] && (( reset_credits > 0 )); then
    printf 'Rate-limit reset credits: %s\n' "$reset_credits"
  fi
  if jq -e '
      .rate_limit.limit_reached == true
      or .code_review_rate_limit.limit_reached == true
      or any(.additional_rate_limits[]?; .rate_limit.limit_reached == true)
      or .rate_limit_reached_type != null
    ' \
    "$cache_file" >/dev/null 2>&1; then
    printf '%s\n' 'Status: usage limit reached'
  fi
  if [[ "$fetched" =~ ^[0-9]+$ ]] && (( fetched > 0 )); then
    printf 'Updated: %s\n' "$(format_epoch "$fetched")"
  fi
  source=$(jq -r '.source // "web"' "$cache_file")
  printf 'Source: %s\n' "$source"
}

refresh_failed=0
if (( refresh )); then
  if acquire_refresh_lock; then
    refresh_cache || refresh_failed=1
  else
    refresh_failed=1
  fi
fi

if [[ "$mode" == refresh-cache ]]; then
  exit "$refresh_failed"
fi

if [[ ! -r "$cache_file" ]]; then
  (( refresh_failed )) || fail 'no cached usage snapshot is available.'
  exit 1
fi

if (( refresh_failed )); then
  now=$(date +%s)
  last_success=0
  if [[ -r "$last_success_file" ]]; then
    IFS= read -r last_success < "$last_success_file" || last_success=0
  fi
  if [[ ! "$last_success" =~ ^[0-9]+$ ]] || (( last_success > now || now - last_success > max_stale_seconds )); then
    fail 'live refresh failed and the cached snapshot is older than the configured maximum age.'
    exit 1
  fi
  printf '%s\n' 'usage-limit: live refresh failed; showing the last cached snapshot.' >&2
fi

case "$mode" in
  json) cat "$cache_file" ;;
  statusline)
    now=$(date +%s)
    last_success=0
    if [[ -r "$last_success_file" ]]; then
      IFS= read -r last_success < "$last_success_file" || last_success=0
    fi
    if [[ "$last_success" =~ ^[0-9]+$ ]] && (( now - last_success <= max_stale_seconds )); then
      IFS= read -r summary < "$summary_file" || summary=""
      printf '%s\n' "$summary"
    fi
    ;;
  *) render_detail ;;
esac
